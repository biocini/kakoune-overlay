#!/usr/bin/env bash
set -euo pipefail

SCRIPTPATH="$(cd "$(dirname "$0")"; pwd -P)"
cd "$SCRIPTPATH"

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

manifest="manifest.json"

# Build set of known repos (owner/repo)
known_file="$TMPDIR/known-repos.txt"
jq -r '.[] | .repo' "$manifest" | sort -u > "$known_file"

# Fetch all repos from GitHub API as JSON Lines
for page in 1 2 3 4; do
  page_file="$TMPDIR/page-$page.json"
  if curl -fsL "https://api.github.com/search/repositories?q=topic:kakoune+topic:plugin&sort=updated&order=desc&per_page=100&page=$page" > "$page_file"; then
    jq -c '.items[] | {full_name, default_branch, description, license: (.license.spdx_id // "")}' "$page_file"
  else
    echo "    WARN: failed to fetch GitHub API page $page" >&2
  fi
done > "$TMPDIR/repos.jsonl"

if [ ! -s "$TMPDIR/repos.jsonl" ]; then
  echo "ERROR: no repos fetched from GitHub API" >&2
  exit 1
fi

# Find repos not in manifest
new_repos="$TMPDIR/new-repos.txt"
while IFS= read -r item; do
  full_name=$(jq -r '.full_name' <<< "$item")
  if ! grep -qx "$full_name" "$known_file"; then
    echo "$item" >> "$new_repos"
  fi
done < "$TMPDIR/repos.jsonl"

if [ ! -s "$new_repos" ]; then
  # Nothing new found; idempotent exit
  exit 0
fi

# Write candidate entries to /tmp/new-plugins.json
echo '{}' > /tmp/new-plugins.json

while IFS= read -r item; do
  owner=$(jq -r '.full_name' <<< "$item" | cut -d/ -f1)
  repo=$(jq -r '.full_name' <<< "$item" | cut -d/ -f2)
  branch=$(jq -r '.default_branch' <<< "$item")
  description=$(jq -r '.description // ""' <<< "$item")
  license=$(jq -r '.license // ""' <<< "$item")

  # Normalize name: replace dots with hyphens, keep everything else
  name=$(echo "$repo" | tr '.' '-')

  # Check if name already exists (different owner, same normalized name)
  if jq -e --arg n "$name" 'has($n)' "$manifest" >/dev/null 2>&1; then
    continue
  fi

  # Fetch latest commit via Atom feed with retry on rate-limit
  feed_file="$TMPDIR/feed-${name}.xml"
  feed_ok=false
  for attempt in 1 2 3; do
    if curl -fsL "https://github.com/$full_name/commits/$branch.atom" > "$feed_file"; then
      feed_ok=true
      break
    fi
    sleep "$((attempt * 2))"
  done
  if [ "$feed_ok" = "false" ]; then
    echo "    WARN: failed to fetch feed for $full_name after 3 attempts" >&2
    continue
  fi

  commit_sha=$(grep -m1 '<id>tag:github.com,2008:Grit::Commit/' "$feed_file" | sed 's/.*Commit\///; s/<\/id>//; s/ //g' || echo "")
  if [ -z "$commit_sha" ] || [ "$commit_sha" = "null" ]; then
    echo "    WARN: no commit found in feed for $full_name" >&2
    continue
  fi

  version_date=$(grep -m1 '<updated>' "$feed_file" | sed 's/.*<updated>//; s/<\/updated>//; s/T.*//; s/ //g' || echo "")

  # Prefetch hash
  if ! hash=$(nix-prefetch-url --unpack "https://github.com/$full_name/archive/$commit_sha.tar.gz"); then
    echo "    WARN: nix-prefetch-url failed for $full_name" >&2
    continue
  fi

  jq --arg name "$name" \
     --arg fetcher "github" \
     --arg repo "$owner/$repo" \
     --arg rev "$commit_sha" \
     --arg sha256 "$hash" \
     --arg version "$version_date" \
     --arg branch "$branch" \
     --arg description "$description" \
     --arg license "$license" \
     '.[$name] = {fetcher: $fetcher, repo: $repo, rev: $rev, sha256: $sha256, version: $version, branch: $branch, description: $description, license: $license}' \
     /tmp/new-plugins.json > /tmp/new-plugins.json.tmp
  mv /tmp/new-plugins.json.tmp /tmp/new-plugins.json

  echo "$name"

  sleep 1
done < "$new_repos"
