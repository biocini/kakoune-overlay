#!/usr/bin/env bash
set -euxo pipefail

SCRIPTPATH="$(cd "$(dirname "$0")"; pwd -P)"
cd "$SCRIPTPATH"

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

manifest="manifest.json"

# ── Phase 1: Discover new plugins ──────────────────────────────────────
# Use GitHub API to find repos with topic:kakoune+topic:plugin.
# This is fast: just metadata, no prefetching.

echo "=== Phase 1: Discovering new plugins ==="

# Build set of known repos (owner/repo)
known_file="$TMPDIR/known-repos.txt"
jq -r '.[] | "\(.owner)/\(.repo)"' "$manifest" 2>/dev/null | sort -u > "$known_file" || true

# Fetch all repos from GitHub API
for page in 1 2 3 4; do
  curl -sL "https://api.github.com/search/repositories?q=topic:kakoune+topic:plugin&sort=updated&order=desc&per_page=100&page=$page" | \
    jq -r '.items[] | "\(.full_name)\t\(.default_branch)"'
done > "$TMPDIR/github-all.txt"

# Find repos not in manifest
new_repos="$TMPDIR/new-repos.txt"
while IFS=$'\t' read -r full_name branch; do
  if ! grep -qx "$full_name" "$known_file"; then
    echo -e "${full_name}\t${branch}" >> "$new_repos"
  fi
done < "$TMPDIR/github-all.txt"

if [ -s "$new_repos" ]; then
  echo "Found $(wc -l < "$new_repos") new plugin(s):"
  cut -f1 "$new_repos"
else
  echo "No new plugins discovered"
fi

# ── Phase 2: Add new plugins to manifest ───────────────────────────────

if [ -s "$new_repos" ]; then
  echo "=== Phase 2: Adding new plugins ==="
  cp "$manifest" "$TMPDIR/manifest-new.json"

  while IFS=$'\t' read -r full_name branch; do
    owner=$(echo "$full_name" | cut -d/ -f1)
    repo=$(echo "$full_name" | cut -d/ -f2)

    # Normalize name
    name="${repo%.kak}"
    name=$(echo "$name" | tr '.' '-')

    # Check if name already exists (different owner, same normalized name)
    if jq -e --arg n "$name" 'has($n)' "$TMPDIR/manifest-new.json" >/dev/null 2>&1; then
      echo "  SKIP $full_name (normalized name '$name' already exists)"
      continue
    fi

    echo "  Adding $full_name as '$name'..."

    # Fetch latest commit via Atom feed
    feed_file="$TMPDIR/feed-${name}.xml"
    if ! curl -sL "https://github.com/$full_name/commits/$branch.atom" > "$feed_file" 2>/dev/null; then
      echo "    WARNING: Could not fetch feed, skipping"
      continue
    fi

    commit_sha=$(grep -m1 '<id>tag:github.com,2008:Grit::Commit/' "$feed_file" | sed 's/.*Commit\///; s/<\/id>//; s/ //g' || true)
    if [ -z "$commit_sha" ] || [ "$commit_sha" = "null" ]; then
      echo "    WARNING: Could not extract commit, skipping"
      continue
    fi

    version_date=$(grep -m1 '<updated>' "$feed_file" | sed 's/.*<updated>//; s/<\/updated>//; s/T.*//; s/ //g' || true)

    # Prefetch hash
    if ! hash=$(nix-prefetch-url --unpack "https://github.com/$full_name/archive/$commit_sha.tar.gz" 2>/dev/null); then
      echo "    WARNING: Could not prefetch, skipping"
      continue
    fi

    jq --arg name "$name" \
       --arg type "github" \
       --arg owner "$owner" \
       --arg repo "$repo" \
       --arg rev "$commit_sha" \
       --arg sha256 "$hash" \
       --arg version "$version_date" \
       --arg branch "$branch" \
       '.[$name] = {type: $type, owner: $owner, repo: $repo, rev: $rev, sha256: $sha256, version: $version, branch: $branch}' \
       "$TMPDIR/manifest-new.json" > "$TMPDIR/manifest-new.json.tmp"
    mv "$TMPDIR/manifest-new.json.tmp" "$TMPDIR/manifest-new.json"

    sleep 0.2
  done < "$new_repos"

  mv "$TMPDIR/manifest-new.json" "$manifest"
fi

# ── Phase 3: Update existing plugins ───────────────────────────────────

echo "=== Phase 3: Updating existing plugins ==="
plugins=$(jq -r 'keys[]' "$manifest")

for plugin in $plugins; do
    meta=$(jq --arg p "$plugin" '.[$p]' "$manifest")
    type=$(echo "$meta" | jq -r '.type')

    if [ "$type" = "github" ]; then
        owner=$(echo "$meta" | jq -r '.owner')
        repo=$(echo "$meta" | jq -r '.repo')
        branch=$(echo "$meta" | jq -r '.branch // "master"')
        echo "Updating $owner/$repo ($branch)"

        feed=$(curl -sL "https://github.com/$owner/$repo/commits/$branch.atom")
        commit_sha=$(echo "$feed" | grep -m1 '<id>tag:github.com,2008:Grit::Commit/' | sed 's/.*Commit\///; s/<\/id>//; s/ //g' || true)

        # Fallback to main if stored branch returns empty
        if [ -z "$commit_sha" ] && [ "$branch" != "main" ]; then
            echo "    Empty feed for '$branch', trying 'main'..."
            feed=$(curl -sL "https://github.com/$owner/$repo/commits/main.atom")
            commit_sha=$(echo "$feed" | grep -m1 '<id>tag:github.com,2008:Grit::Commit/' | sed 's/.*Commit\///; s/<\/id>//; s/ //g' || true)
            if [ -n "$commit_sha" ]; then
                branch="main"
            fi
        fi

        if [ -z "$commit_sha" ]; then
            echo "    WARNING: Could not get commit for $owner/$repo, skipping"
            continue
        fi

        version_date=$(echo "$feed" | grep -m1 '<updated>' | sed 's/.*<updated>//; s/<\/updated>//; s/T.*//; s/ //g' || true)

        digest=$(nix-prefetch-url --unpack "https://github.com/$owner/$repo/archive/$commit_sha.tar.gz")

        jq --arg p "$plugin" \
           --arg rev "$commit_sha" \
           --arg sha256 "$digest" \
           --arg version "$version_date" \
           --arg branch "$branch" \
           '.[$p].rev = $rev | .[$p].sha256 = $sha256 | .[$p].version = $version | .[$p].branch = $branch' \
           "$manifest" > "$TMPDIR/manifest.json"
        mv "$TMPDIR/manifest.json" "$manifest"

    elif [ "$type" = "gitlab" ]; then
        owner=$(echo "$meta" | jq -r '.owner')
        repo=$(echo "$meta" | jq -r '.repo')
        echo "Updating gitlab $owner/$repo"

        commit_sha=$(curl -sL "https://gitlab.com/api/v4/projects/$(printf '%s' "$owner/$repo" | jq -sRr @uri)/repository/commits?per_page=1" | jq -r '.[0].id')
        version_date=$(curl -sL "https://gitlab.com/api/v4/projects/$(printf '%s' "$owner/$repo" | jq -sRr @uri)/repository/commits/$commit_sha" | jq -r '.committed_date' | cut -dT -f1)
        digest=$(nix-prefetch-url --unpack "https://gitlab.com/$owner/$repo/-/archive/$commit_sha/$repo-$commit_sha.tar.gz")

        jq --arg p "$plugin" \
           --arg rev "$commit_sha" \
           --arg sha256 "$digest" \
           --arg version "$version_date" \
           '.[$p].rev = $rev | .[$p].sha256 = $sha256 | .[$p].version = $version' \
           "$manifest" > "$TMPDIR/manifest.json"
        mv "$TMPDIR/manifest.json" "$manifest"

    elif [ "$type" = "git" ]; then
        url=$(echo "$meta" | jq -r '.url')
        echo "Updating $url"

        info=$(nix-prefetch-git --no-deepClone "$url")
        rev=$(echo "$info" | jq -r '.rev')
        sha256=$(echo "$info" | jq -r '.sha256')
        version_date=$(echo "$info" | jq -r '.date' | cut -dT -f1)

        jq --arg p "$plugin" \
           --arg rev "$rev" \
           --arg sha256 "$sha256" \
           --arg version "$version_date" \
           '.[$p].rev = $rev | .[$p].sha256 = $sha256 | .[$p].version = $version' \
           "$manifest" > "$TMPDIR/manifest.json"
        mv "$TMPDIR/manifest.json" "$manifest"
    fi
done
