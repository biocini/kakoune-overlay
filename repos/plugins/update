#!/usr/bin/env bash
set -euo pipefail

SCRIPTPATH="$(cd "$(dirname "$0")"; pwd -P)"
cd "$SCRIPTPATH"

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

manifest="manifest.json"
updated=0
skipped=0
failed=0

echo "=== Checking for plugin updates ==="
plugins=$(jq -r 'keys[]' "$manifest")

for plugin in $plugins; do
    meta=$(jq --arg p "$plugin" '.[$p]' "$manifest")
    fetcher=$(echo "$meta" | jq -r '.fetcher')
    current_rev=$(echo "$meta" | jq -r '.rev')

    if [ "$fetcher" = "github" ]; then
        repo=$(echo "$meta" | jq -r '.repo')
        branch=$(echo "$meta" | jq -r '.branch // "master"')

        feed=$(curl -fsL "https://github.com/$repo/commits/$branch.atom")
        commit_sha=$(echo "$feed" | grep -m1 '<id>tag:github.com,2008:Grit::Commit/' | sed 's/.*Commit\///; s/<\/id>//; s/ //g' || true)

        # Fallback to main if stored branch returns empty
        if [ -z "$commit_sha" ] && [ "$branch" != "main" ]; then
            feed=$(curl -fsL "https://github.com/$repo/commits/main.atom")
            commit_sha=$(echo "$feed" | grep -m1 '<id>tag:github.com,2008:Grit::Commit/' | sed 's/.*Commit\///; s/<\/id>//; s/ //g' || true)
            if [ -n "$commit_sha" ]; then
                branch="main"
            fi
        fi

        if [ -z "$commit_sha" ]; then
            echo "  SKIP $plugin: could not fetch feed for $repo"
            failed=$((failed + 1))
            continue
        fi

        if [ "$commit_sha" = "$current_rev" ]; then
            skipped=$((skipped + 1))
            continue
        fi

        version_date=$(echo "$feed" | grep -m1 '<updated>' | sed 's/.*<updated>//; s/<\/updated>//; s/T.*//; s/ //g' || true)
        digest=$(nix-prefetch-url --unpack "https://github.com/$repo/archive/$commit_sha.tar.gz")

        jq --arg p "$plugin" \
           --arg rev "$commit_sha" \
           --arg sha256 "$digest" \
           --arg version "$version_date" \
           --arg branch "$branch" \
           '.[$p].rev = $rev | .[$p].sha256 = $sha256 | .[$p].version = $version | .[$p].branch = $branch' \
           "$manifest" > "$TMPDIR/manifest.json"
        mv "$TMPDIR/manifest.json" "$manifest"
        echo "  UPDATED $plugin: $current_rev -> $commit_sha"
        updated=$((updated + 1))

    elif [ "$fetcher" = "gitlab" ]; then
        repo=$(echo "$meta" | jq -r '.repo')

        commit_sha=$(curl -fsL "https://gitlab.com/api/v4/projects/$(printf '%s' "$repo" | jq -sRr @uri)/repository/commits?per_page=1" | jq -r '.[0].id')

        if [ "$commit_sha" = "$current_rev" ]; then
            skipped=$((skipped + 1))
            continue
        fi

        version_date=$(curl -fsL "https://gitlab.com/api/v4/projects/$(printf '%s' "$repo" | jq -sRr @uri)/repository/commits/$commit_sha" | jq -r '.committed_date' | cut -dT -f1)
        digest=$(nix-prefetch-url --unpack "https://gitlab.com/$repo/-/archive/$commit_sha/$(basename "$repo")-$commit_sha.tar.gz")

        jq --arg p "$plugin" \
           --arg rev "$commit_sha" \
           --arg sha256 "$digest" \
           --arg version "$version_date" \
           '.[$p].rev = $rev | .[$p].sha256 = $sha256 | .[$p].version = $version' \
           "$manifest" > "$TMPDIR/manifest.json"
        mv "$TMPDIR/manifest.json" "$manifest"
        echo "  UPDATED $plugin: $current_rev -> $commit_sha"
        updated=$((updated + 1))

    elif [ "$fetcher" = "git" ]; then
        url=$(echo "$meta" | jq -r '.repo')

        info=$(nix-prefetch-git --no-deepClone "$url")
        rev=$(echo "$info" | jq -r '.rev')

        if [ "$rev" = "$current_rev" ]; then
            skipped=$((skipped + 1))
            continue
        fi

        sha256=$(echo "$info" | jq -r '.sha256')
        version_date=$(echo "$info" | jq -r '.date' | cut -dT -f1)

        jq --arg p "$plugin" \
           --arg rev "$rev" \
           --arg sha256 "$sha256" \
           --arg version "$version_date" \
           '.[$p].rev = $rev | .[$p].sha256 = $sha256 | .[$p].version = $version' \
           "$manifest" > "$TMPDIR/manifest.json"
        mv "$TMPDIR/manifest.json" "$manifest"
        echo "  UPDATED $plugin: $current_rev -> $rev"
        updated=$((updated + 1))
    fi
done

echo ""
echo "=== Summary: $updated updated, $skipped up-to-date, $failed failed ==="
