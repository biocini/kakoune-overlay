#!/usr/bin/env bash
set -euxo pipefail

SCRIPTPATH="$(cd "$(dirname "$0")"; pwd -P)"
cd "$SCRIPTPATH"

update_github() {
    local owner="$1" repo="$2" file="$3" branch="${4:-master}"
    echo "Updating $owner/$repo"

    # Use GitHub Atom feed — no API auth/rate limits
    local commit_data
    commit_data=$(curl -sL "https://github.com/$owner/$repo/commits/$branch.atom" | \
        grep -m1 '<id>tag:github.com,2008:Grit::Commit/' | \
        sed 's/.*Commit\///; s/<\/id>//; s/ //g')

    local commit_sha="$commit_data"

    local version_date
    version_date=$(curl -sL "https://github.com/$owner/$repo/commits/$branch.atom" | \
        grep -m1 '<updated>' | \
        sed 's/.*<updated>//; s/<\/updated>//; s/T.*//; s/ //g')

    local digest
    digest=$(nix-prefetch-url --unpack "https://github.com/$owner/$repo/archive/$commit_sha.tar.gz")

    jq -n \
        --arg type "github" \
        --arg owner "$owner" \
        --arg repo "$repo" \
        --arg rev "$commit_sha" \
        --arg sha256 "$digest" \
        --arg version "$version_date" \
        '{type: $type, owner: $owner, repo: $repo, rev: $rev, sha256: $sha256, version: $version}' \
        > "$file"
}

update_github_tag() {
    local owner="$1" repo="$2" file="$3"
    echo "Updating $owner/$repo (latest tag)"

    local tag_data
    tag_data=$(curl -sL "https://api.github.com/repos/$owner/$repo/releases/latest" | \
        jq -r '.tag_name')

    local digest
    digest=$(nix-prefetch-url --unpack "https://github.com/$owner/$repo/archive/refs/tags/$tag_data.tar.gz")

    # Strip leading 'v' from version string
    local version="${tag_data#v}"

    jq -n \
        --arg type "github" \
        --arg owner "$owner" \
        --arg repo "$repo" \
        --arg rev "$tag_data" \
        --arg sha256 "$digest" \
        --arg version "$version" \
        '{type: $type, owner: $owner, repo: $repo, rev: $rev, sha256: $sha256, version: $version}' \
        > "$file"
}

update_git() {
    local url="$1" file="$2"
    echo "Updating $url"

    local info
    info=$(nix-prefetch-git --no-deepClone "$url")

    local rev sha256 version_date
    rev=$(echo "$info" | jq -r '.rev')
    sha256=$(echo "$info" | jq -r '.sha256')
    version_date=$(echo "$info" | jq -r '.date' | cut -dT -f1)

    jq -n \
        --arg type "git" \
        --arg url "$url" \
        --arg rev "$rev" \
        --arg sha256 "$sha256" \
        --arg version "$version_date" \
        '{type: $type, url: $url, rev: $rev, sha256: $sha256, version: $version}' \
        > "$file"
}

update_github "mawww" "kakoune" "kakoune.json"
update_github_tag "mawww" "kakoune" "kakoune-stable.json"
update_git "https://git.sr.ht/~hadronized/kak-tree-sitter" "kak-tree-sitter.json"
